# Claude Supervisor — Environment Configuration
# Copy to .env and uncomment what you need.

# Server
# SUPERVISOR_PORT=3847
# SUPERVISOR_PASSWORD=your-dashboard-password

# MQTT Broker
# SUPERVISOR_MQTT_HOST=localhost

# Supervisor Mode
# SUPERVISOR_MODE=auto   # auto | assisted | manual

# Evaluator Backend (choose one)
# Default: Ollama (local LLM) — set SUPERVISOR_EVAL_BACKEND=claude to use Claude CLI instead.
#
# Ollama (local LLM):
# SUPERVISOR_EVAL_BACKEND=ollama
# SUPERVISOR_OLLAMA_URL=http://localhost:11434
#
# Claude CLI:
# SUPERVISOR_EVAL_BACKEND=claude
#
# Anthropic API:
# ANTHROPIC_API_KEY=sk-ant-...

# Evaluator Tuning
# SUPERVISOR_CONFIDENCE_THRESHOLD=0.80
# SUPERVISOR_EVAL_ESCALATION_THRESHOLD=70
