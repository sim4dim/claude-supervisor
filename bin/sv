#!/usr/bin/env bash
# sv — supervisor MQTT helper for Claude Code agents
#
# Usage:
#   sv pub status started "Investigating auth bug"
#   sv pub status completed
#   sv pub progress 50 "Found 3 affected files"
#   sv pub discovery "Auth tokens expire after 1h"
#   sv pub coordination "Interface changed: getUserById returns Promise<User|null>"
#   sv chat post mytopic "PROPOSAL #1: Eliminate dual control path"
#   sv chat wait mytopic 5           # wait for seq >= 5
#   sv chat read mytopic             # read latest message
#   sv chat history mytopic          # read all messages in room
#   sv chat clear mytopic            # clear retained messages
#   sv chat post --project shared myroom "hello"   # cross-project room
#   sv chat history --project shared myroom        # read cross-project room
#   sv read some/topic               # read one message (retained or next published)
#   sv retain some/topic '{"key":"val"}'  # publish retained message
#   sv clear some/topic              # clear retained message
#   sv request "Check auth schema" --project auth-service
#   sv respond <request-id> "Schema uses JWT tokens"
#   sv request wait <request-id> 120
#   sv task create "Add email digest" [--priority 2] [--blocked-by sv-a1b2c3]
#   sv task list [--status pending|in_progress|completed|all]
#   sv task ready
#   sv task update <id> --status in_progress
#   sv task start <id>
#   sv task close <id>
#   sv remember "Auth tokens expire after 1h" [--world] [--type <type>] [--tier L1|L2|L3] [--tags '["tag"]'] [--project <name>]
#   sv recall [<query>] [--world] [--global] [--project <name>] [--limit N] [--startup]

set -euo pipefail

MQTT_HOST="${SUPERVISOR_MQTT_HOST:-localhost}"
MQTT_BACKUP="${SUPERVISOR_MQTT_BACKUP_HOST:-}"
MQTT_BACKUP_USER="${SUPERVISOR_MQTT_BACKUP_USER:-}"
MQTT_BACKUP_PASS="${SUPERVISOR_MQTT_BACKUP_PASS:-}"
PROJECT="${SV_PROJECT:-$(basename "${CLAUDE_PROJECT_DIR:-$PWD}")}"
export SV_PROJECT="$PROJECT"
TASK_ID="${SV_TASK_ID:-agent}"

_backup_args() {
  local args=(-h "$MQTT_BACKUP")
  [[ -n "$MQTT_BACKUP_USER" ]] && args+=(-u "$MQTT_BACKUP_USER")
  [[ -n "$MQTT_BACKUP_PASS" ]] && args+=(-P "$MQTT_BACKUP_PASS")
  echo "${args[@]}"
}

_pub() {
  if timeout 3 mosquitto_pub -h "$MQTT_HOST" "$@" 2>/dev/null; then
    # Also replicate to backup (fire and forget)
    if [[ -n "$MQTT_BACKUP" ]]; then
      local backup_args=(-h "$MQTT_BACKUP")
      [[ -n "$MQTT_BACKUP_USER" ]] && backup_args+=(-u "$MQTT_BACKUP_USER")
      [[ -n "$MQTT_BACKUP_PASS" ]] && backup_args+=(-P "$MQTT_BACKUP_PASS")
      timeout 3 mosquitto_pub "${backup_args[@]}" "$@" 2>/dev/null &
    fi
  elif [[ -n "$MQTT_BACKUP" ]]; then
    # Primary failed, try backup
    local backup_args=(-h "$MQTT_BACKUP")
    [[ -n "$MQTT_BACKUP_USER" ]] && backup_args+=(-u "$MQTT_BACKUP_USER")
    [[ -n "$MQTT_BACKUP_PASS" ]] && backup_args+=(-P "$MQTT_BACKUP_PASS")
    timeout 3 mosquitto_pub "${backup_args[@]}" "$@" 2>/dev/null
  else
    return 1
  fi
}

_sub() {
  # Try primary first
  if mosquitto_sub -h "$MQTT_HOST" "$@" 2>/dev/null; then
    return 0
  fi
  # Primary failed — try backup if configured
  if [[ -n "$MQTT_BACKUP" ]]; then
    local backup_args=(-h "$MQTT_BACKUP")
    [[ -n "$MQTT_BACKUP_USER" ]] && backup_args+=(-u "$MQTT_BACKUP_USER")
    [[ -n "$MQTT_BACKUP_PASS" ]] && backup_args+=(-P "$MQTT_BACKUP_PASS")
    mosquitto_sub "${backup_args[@]}" "$@" 2>/dev/null
  else
    return 1
  fi
}

# Build JSON object from key=value pairs. Numeric values auto-detected.
# Strips \! artifacts from shell escaping.
_json() {
  python3 -c "
import json, sys
obj = {}
for kv in sys.argv[1:]:
    k, v = kv.split('=', 1)
    v = v.replace('\\\!', '!')
    try:
        v = int(v)
    except ValueError:
        try:
            v = float(v)
        except ValueError:
            pass
    obj[k] = v
print(json.dumps(obj, ensure_ascii=False))
" "$@"
}

# ─── sv pub ──────────────────────────────────────────────────────────────────

cmd_pub() {
  local type="${1:?Usage: sv pub <status|progress|discovery|coordination> ...}"
  shift

  case "$type" in
    status)
      local status="${1:?Usage: sv pub status <started|completed|failed> [description]}"
      local desc="${2:-}"
      if [[ -n "$desc" ]]; then
        _pub -t "supervisor/$PROJECT/$TASK_ID/status" -m "$(_json "status=$status" "description=$desc")"
      else
        _pub -t "supervisor/$PROJECT/$TASK_ID/status" -m "$(_json "status=$status")"
      fi
      ;;
    progress)
      local pct="${1:?Usage: sv pub progress <percent> <message>}"
      local msg="${2:?Usage: sv pub progress <percent> <message>}"
      _pub -t "supervisor/$PROJECT/$TASK_ID/progress" -m "$(_json "percent=$pct" "message=$msg")"
      ;;
    discovery)
      local finding="${1:?Usage: sv pub discovery <finding>}"
      _pub -t "supervisor/$PROJECT/$TASK_ID/discovery" -m "$(_json "finding=$finding")"
      ;;
    coordination)
      local msg="${1:?Usage: sv pub coordination <message>}"
      _pub -t "supervisor/$PROJECT/$TASK_ID/coordination" -m "$(_json "message=$msg")"
      ;;
    alert)
      local alert_type="${1:?Usage: sv pub alert <type> <message>}"
      local alert_msg="${2:?Usage: sv pub alert <type> <message>}"
      _pub -t "supervisor/$PROJECT/alert/$alert_type" -m "$(_json "type=$alert_type" "message=$alert_msg" "severity=alert" "ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)")"
      ;;
    *)
      echo "Unknown pub type: $type (use status|progress|discovery|coordination|alert)" >&2
      exit 1
      ;;
  esac
}

# ─── sv chat ─────────────────────────────────────────────────────────────────

_chat_topic() { echo "supervisor/$1/chat/$2"; }
_chat_seq_topic() { echo "supervisor/$1/chat/$2/seq"; }
_chat_msg_topic() { echo "supervisor/$1/chat/$2/messages/$3"; }

cmd_chat() {
  local action="${1:?Usage: sv chat <post|wait|read|clear|init|history> <room> ...}"
  shift

  # Optional --project flag overrides PROJECT for this chat command
  local CHAT_PROJECT="$PROJECT"
  if [[ "${1:-}" == "--project" ]]; then
    CHAT_PROJECT="${2:?--project requires a value}"
    shift 2
  fi

  case "$action" in
    init)
      local room="${1:?Usage: sv chat init <room>}"
      # Read current seq to know how many message topics to clear
      local cur_seq
      cur_seq=$(_sub -t "$(_chat_seq_topic "$CHAT_PROJECT" "$room")" -C 1 -W 2 2>/dev/null || echo "0")
      # Clear existing per-message topics (cap at 100 for efficiency)
      if [[ "$cur_seq" -gt 0 ]] 2>/dev/null; then
        local max=$((cur_seq > 100 ? 100 : cur_seq))
        for ((i=1; i<=max; i++)); do
          _pub -r -n -t "$(_chat_msg_topic "$CHAT_PROJECT" "$room" "$i")"
        done
      fi
      # Clear legacy room topic
      _pub -r -n -t "$(_chat_topic "$CHAT_PROJECT" "$room")"
      # Reset seq counter to 0
      _pub -r -n -t "$(_chat_seq_topic "$CHAT_PROJECT" "$room")"
      _pub -r -t "$(_chat_seq_topic "$CHAT_PROJECT" "$room")" -m "0"
      ;;
    post)
      local room="${1:?Usage: sv chat post <room> <message>}"
      local msg="${2:?Usage: sv chat post <room> <message>}"
      local from="${SV_AGENT_NAME:-$TASK_ID}"
      local cur_seq
      cur_seq=$(_sub -t "$(_chat_seq_topic "$CHAT_PROJECT" "$room")" -C 1 -W 5 2>/dev/null || echo "0")
      local next_seq=$((cur_seq + 1))
      # Publish to per-message retained topic
      _pub -r -t "$(_chat_msg_topic "$CHAT_PROJECT" "$room" "$next_seq")" \
        -m "$(_json "from=$from" "seq=$next_seq" "msg=$msg")"
      # Update seq counter
      _pub -r -t "$(_chat_seq_topic "$CHAT_PROJECT" "$room")" -m "$next_seq"
      echo "$next_seq"
      ;;
    wait)
      local room="${1:?Usage: sv chat wait <room> <target-seq> [timeout]}"
      local target="${2:?Usage: sv chat wait <room> <target-seq> [timeout]}"
      local timeout="${3:-120}"
      local elapsed=0 seq=0
      while [[ $elapsed -lt $timeout ]]; do
        seq=$(_sub -t "$(_chat_seq_topic "$CHAT_PROJECT" "$room")" -C 1 -W 3 2>/dev/null || echo "0")
        if [[ "$seq" -ge "$target" ]] 2>/dev/null; then
          # Read the specific message topic for the target seq
          _sub -t "$(_chat_msg_topic "$CHAT_PROJECT" "$room" "$target")" -C 1 -W 5 2>/dev/null
          return 0
        fi
        elapsed=$((elapsed + 3))
      done
      echo "Timeout waiting for seq >= $target (got $seq after ${timeout}s)" >&2
      return 1
      ;;
    read)
      local room="${1:?Usage: sv chat read <room> [timeout]}"
      local timeout="${2:-10}"
      # Read current seq, then fetch that specific message
      local cur_seq
      cur_seq=$(_sub -t "$(_chat_seq_topic "$CHAT_PROJECT" "$room")" -C 1 -W "$timeout" 2>/dev/null || echo "0")
      if [[ "$cur_seq" -gt 0 ]] 2>/dev/null; then
        _sub -t "$(_chat_msg_topic "$CHAT_PROJECT" "$room" "$cur_seq")" -C 1 -W 5 2>/dev/null
      fi
      ;;
    history)
      local room="${1:?Usage: sv chat history <room>}"
      local cur_seq
      cur_seq=$(_sub -t "$(_chat_seq_topic "$CHAT_PROJECT" "$room")" -C 1 -W 5 2>/dev/null || echo "0")
      if [[ "$cur_seq" -le 0 ]] 2>/dev/null; then
        echo "No messages in room '$room'" >&2
        return 0
      fi
      for ((i=1; i<=cur_seq; i++)); do
        _sub -t "$(_chat_msg_topic "$CHAT_PROJECT" "$room" "$i")" -C 1 -W 2 2>/dev/null
      done
      ;;
    clear)
      local room="${1:?Usage: sv chat clear <room>}"
      local cur_seq
      cur_seq=$(_sub -t "$(_chat_seq_topic "$CHAT_PROJECT" "$room")" -C 1 -W 5 2>/dev/null || echo "0")
      # Clear per-message topics (cap at 100 for efficiency)
      if [[ "$cur_seq" -gt 0 ]] 2>/dev/null; then
        local max=$((cur_seq > 100 ? 100 : cur_seq))
        for ((i=1; i<=max; i++)); do
          _pub -r -n -t "$(_chat_msg_topic "$CHAT_PROJECT" "$room" "$i")"
        done
      fi
      # Clear legacy room topic and seq counter
      _pub -r -n -t "$(_chat_topic "$CHAT_PROJECT" "$room")"
      _pub -r -n -t "$(_chat_seq_topic "$CHAT_PROJECT" "$room")"
      ;;
    *)
      echo "Unknown chat action: $action (use init|post|wait|read|clear|history)" >&2; exit 1
      ;;
  esac
}

# ─── sv read / retain / clear ───────────────────────────────────────────────

cmd_read() {
  local topic="${1:?Usage: sv read <topic> [timeout]}"
  local timeout="${2:-30}"
  _sub -t "$topic" -C 1 -W "$timeout" 2>/dev/null
}

cmd_retain() {
  local topic="${1:?Usage: sv retain <topic> <json>}"
  local payload="${2:?Usage: sv retain <topic> <json>}"
  _pub -r -t "$topic" -m "$payload"
}

cmd_clear() {
  local topic="${1:?Usage: sv clear <topic>}"
  _pub -r -n -t "$topic"
}

# ─── sv request / respond ─────────────────────────────────────────────────────

cmd_request() {
  # If first arg is "wait", handle the wait subcommand
  if [[ "${1:-}" == "wait" ]]; then
    shift
    local request_id="${1:?Usage: sv request wait <request-id> [timeout]}"
    local timeout="${2:-120}"
    local instance="${SV_INSTANCE:-$(hostname -s)}"
    _sub -t "coordinator/${instance}/responses/${request_id}" -C 1 -W "$timeout" 2>/dev/null
    return $?
  fi

  local desc=""
  local target_project=""
  local req_type="research"
  local context=""
  local timeout=300
  local env_pairs=()

  # Parse args: first positional is description, then flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project) target_project="$2"; shift 2 ;;
      --type) req_type="$2"; shift 2 ;;
      --context) context="$2"; shift 2 ;;
      --timeout) timeout="$2"; shift 2 ;;
      --env) env_pairs+=("$2"); shift 2 ;;
      *)
        if [[ -z "$desc" ]]; then
          desc="$1"
        else
          desc="$desc $1"
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$desc" ]]; then
    echo "Usage: sv request <description> [--project <name>] [--type <type>] [--timeout <secs>] [--env KEY=VALUE]" >&2
    exit 1
  fi

  local instance="${SV_INSTANCE:-$(hostname -s)}"
  local request_id
  request_id=$(python3 -c "import uuid; print(uuid.uuid4())")
  local from_agent="${SV_AGENT_NAME:-$TASK_ID}"

  local payload
  payload=$(python3 -c "
import json, sys, os
# Args: request_id, instance, from_agent, type, description, context, target_project, timeout, env_pairs...
request_id, instance, from_agent, req_type, desc, context, target_project, timeout = sys.argv[1:9]
env_pairs = sys.argv[9:]
env_obj = {}
for pair in env_pairs:
    k, v = pair.split('=', 1)
    env_obj[k] = v
obj = {
    'id': request_id,
    'from': {
        'instance': instance,
        'project': os.environ.get('SV_PROJECT', os.environ.get('PROJECT', 'unknown')),
        'agent': from_agent
    },
    'type': req_type,
    'description': desc,
    'context': context,
    'target_project': target_project,
    'priority': 'normal',
    'timeout': int(timeout),
    'timestamp': __import__('datetime').datetime.now(__import__('datetime').timezone.utc).isoformat().replace('+00:00', 'Z')
}
if env_obj:
    obj['env'] = env_obj
print(json.dumps(obj, ensure_ascii=False))
" "$request_id" "$instance" "$from_agent" "$req_type" "$desc" "$context" "$target_project" "$timeout" "${env_pairs[@]+"${env_pairs[@]}"}")

  _pub -r -t "coordinator/${instance}/requests/${request_id}" -m "$payload"
  echo "$request_id"
}

cmd_respond() {
  local request_id="${1:?Usage: sv respond <request-id> <result>}"
  local result="${2:?Usage: sv respond <request-id> <result>}"

  local payload
  payload=$(python3 -c "
import json, sys, uuid, datetime
obj = {
    'id': str(uuid.uuid4()),
    'request_id': sys.argv[1],
    'status': 'completed',
    'result': sys.argv[2],
    'agent': sys.argv[3],
    'timestamp': datetime.datetime.now(datetime.timezone.utc).isoformat().replace('+00:00', 'Z')
}
print(json.dumps(obj, ensure_ascii=False))
" "$request_id" "$result" "${SV_AGENT_NAME:-$TASK_ID}")

  local instance="${SV_INSTANCE:-$(hostname -s)}"
  _pub -r -t "coordinator/${instance}/responses/${request_id}" -m "$payload"
  echo "Response published for $request_id"
}

# ─── sv task ─────────────────────────────────────────────────────────────────

_tasks_file() {
  local dir="${CLAUDE_PROJECT_DIR:-$PWD}/.claude"
  mkdir -p "$dir"
  echo "$dir/tasks.jsonl"
}

_tasks_read() {
  # Read JSONL, reduce to latest entry per id, return as JSON array
  local file="$1"
  python3 -c "
import json, sys
tasks = {}
try:
    with open(sys.argv[1]) as f:
        for line in f:
            line = line.strip()
            if line:
                obj = json.loads(line)
                tasks[obj['id']] = obj
except FileNotFoundError:
    pass
print(json.dumps(list(tasks.values()), ensure_ascii=False))
" "$file"
}

cmd_task() {
  local action="${1:?Usage: sv task <create|list|ready|update|start|close> ...}"
  shift
  local tasks_file
  tasks_file=$(_tasks_file)

  case "$action" in
    create)
      local subject="${1:?Usage: sv task create \"<subject>\" [--priority N] [--blocked-by id1,id2]}"
      shift
      local priority=2
      local blocked_by="[]"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --priority)   priority="$2"; shift 2 ;;
          --blocked-by) blocked_by=$(python3 -c "import json,sys; print(json.dumps(sys.argv[1].split(',')))" "$2"); shift 2 ;;
          *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
      done
      python3 -c "
import json, uuid, datetime, sys
task_id = 'sv-' + uuid.uuid4().hex[:6]
now = datetime.datetime.now(datetime.timezone.utc).isoformat().replace('+00:00', 'Z')
obj = {
    'id': task_id,
    'created': now,
    'updated': now,
    'subject': sys.argv[1],
    'status': 'pending',
    'priority': int(sys.argv[2]),
    'blocked_by': json.loads(sys.argv[3]),
    'project': sys.argv[4],
}
with open(sys.argv[5], 'a') as f:
    f.write(json.dumps(obj, ensure_ascii=False) + '\n')
print(task_id)
" "$subject" "$priority" "$blocked_by" "$PROJECT" "$tasks_file"
      ;;

    list)
      local filter_status="active"
      if [[ $# -gt 0 && "${1:-}" == "--status" ]]; then
        filter_status="$2"; shift 2
      fi
      python3 -c "
import json, sys
tasks = {}
try:
    with open(sys.argv[1]) as f:
        for line in f:
            line = line.strip()
            if line:
                obj = json.loads(line)
                tasks[obj['id']] = obj
except FileNotFoundError:
    pass
filter_status = sys.argv[2]
rows = sorted(tasks.values(), key=lambda t: (t.get('priority', 2), t.get('created', '')))
for t in rows:
    s = t.get('status', '')
    if filter_status == 'all' or \
       (filter_status == 'active' and s in ('pending', 'in_progress')) or \
       filter_status == s:
        blocked = ','.join(t.get('blocked_by', [])) or '-'
        print(f\"{t['id']}  {s:<12}  p{t.get('priority',2)}  {t.get('subject','')}  [blocked_by: {blocked}]\")
" "$tasks_file" "$filter_status"
      ;;

    ready)
      python3 -c "
import json, sys
tasks = {}
try:
    with open(sys.argv[1]) as f:
        for line in f:
            line = line.strip()
            if line:
                obj = json.loads(line)
                tasks[obj['id']] = obj
except FileNotFoundError:
    pass
def is_completed(tid):
    t = tasks.get(tid)
    return t is not None and t.get('status') == 'completed'
rows = sorted(tasks.values(), key=lambda t: (t.get('priority', 2), t.get('created', '')))
for t in rows:
    if t.get('status') != 'pending':
        continue
    blockers = t.get('blocked_by', [])
    if all(is_completed(b) for b in blockers):
        print(f\"{t['id']}  p{t.get('priority',2)}  {t.get('subject','')}\")
" "$tasks_file"
      ;;

    update)
      local task_id="${1:?Usage: sv task update <id> --status <new_status>}"
      shift
      local new_status=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --status) new_status="$2"; shift 2 ;;
          *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
      done
      [[ -z "$new_status" ]] && { echo "Usage: sv task update <id> --status <new_status>" >&2; exit 1; }
      python3 -c "
import json, sys, datetime
task_id, new_status, tasks_file = sys.argv[1], sys.argv[2], sys.argv[3]
tasks = {}
try:
    with open(tasks_file) as f:
        for line in f:
            line = line.strip()
            if line:
                obj = json.loads(line)
                tasks[obj['id']] = obj
except FileNotFoundError:
    pass
if task_id not in tasks:
    print(f'Task not found: {task_id}', file=sys.stderr)
    sys.exit(1)
updated = dict(tasks[task_id])
updated['status'] = new_status
updated['updated'] = datetime.datetime.now(datetime.timezone.utc).isoformat().replace('+00:00', 'Z')
with open(tasks_file, 'a') as f:
    f.write(json.dumps(updated, ensure_ascii=False) + '\n')
print(f'Updated {task_id} -> {new_status}')
" "$task_id" "$new_status" "$tasks_file"
      ;;

    start)
      local task_id="${1:?Usage: sv task start <id>}"
      cmd_task update "$task_id" --status in_progress
      ;;

    close)
      local task_id="${1:?Usage: sv task close <id>}"
      cmd_task update "$task_id" --status completed
      ;;

    *)
      echo "Unknown task action: $action (use create|list|ready|update|start|close)" >&2; exit 1
      ;;
  esac
}

# ─── sv remember ─────────────────────────────────────────────────────────────

cmd_remember() {
  local content=""
  local type="discovery"
  local scope="project"
  local project="${SV_PROJECT:-$(basename "${CLAUDE_PROJECT_DIR:-$(pwd)}")}"
  local tier="L2"
  local tags="[]"

  # Parse flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --world)    scope="world"; project="_world"; tier="L1"; shift ;;
      --type)     type="$2"; shift 2 ;;
      --tier)     tier="$2"; shift 2 ;;
      --tags)     tags="$2"; shift 2 ;;
      --project)  project="$2"; shift 2 ;;
      *)          content="$content $1"; shift ;;
    esac
  done
  content="${content# }"  # trim leading space

  if [[ -z "$content" ]]; then
    echo "Usage: sv remember <content> [--world] [--type <type>] [--tags '<json>']" >&2
    exit 1
  fi

  local port="${SUPERVISOR_PORT:-3847}"
  local token
  token=$(cat "$HOME/.claude/.supervisor-hook-token" 2>/dev/null || echo "")

  if [[ -z "$token" ]]; then
    echo "Error: No supervisor hook token found at ~/.claude/.supervisor-hook-token" >&2
    exit 1
  fi

  # Build JSON payload using Python for safe escaping (tags is already a JSON value)
  local payload
  payload=$(python3 -c "
import json, sys
content, type_, scope, project, tier, tags_str, source = sys.argv[1:]
try:
    tags = json.loads(tags_str)
except Exception:
    tags = []
obj = {
    'content': content,
    'type': type_,
    'scope': scope,
    'project': project,
    'tier': tier,
    'tags': tags,
    'source': source,
}
print(json.dumps(obj, ensure_ascii=False))
" "$content" "$type" "$scope" "$project" "$tier" "$tags" "sv-cli")

  local result
  result=$(curl -s -X POST "http://localhost:${port}/api/pensive/remember" \
    -H "Authorization: Bearer ${token}" \
    -H "Content-Type: application/json" \
    -d "$payload" 2>/dev/null)

  if [[ $? -eq 0 && -n "$result" ]]; then
    echo "$result"
  else
    echo "Error: Could not reach supervisor at localhost:${port}" >&2
    exit 1
  fi
}

# ─── sv recall ───────────────────────────────────────────────────────────────

cmd_recall() {
  local query=""
  local scope=""
  local project="${SV_PROJECT:-$(basename "${CLAUDE_PROJECT_DIR:-$(pwd)}")}"
  local limit="10"
  local startup=""

  # Parse flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --world)    scope="world"; shift ;;
      --global)   scope=""; project=""; shift ;;
      --project)  project="$2"; shift 2 ;;
      --limit)    limit="$2"; shift 2 ;;
      --startup)  startup="true"; shift ;;
      *)          query="$query $1"; shift ;;
    esac
  done
  query="${query# }"

  local port="${SUPERVISOR_PORT:-3847}"
  local token
  token=$(cat "$HOME/.claude/.supervisor-hook-token" 2>/dev/null || echo "")

  if [[ -z "$token" ]]; then
    echo "Error: No supervisor hook token found at ~/.claude/.supervisor-hook-token" >&2
    exit 1
  fi

  # Build query string
  local qs="limit=${limit}"
  [[ -n "$query" ]] && qs="${qs}&query=$(python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1]))" "$query")"
  [[ -n "$project" ]] && qs="${qs}&project=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$project'))")"
  [[ -n "$scope" ]] && qs="${qs}&scope=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$scope'))")"
  [[ -n "$startup" ]] && qs="${qs}&startup=true"

  local result
  result=$(curl -s "http://localhost:${port}/api/pensive/memories?${qs}" \
    -H "Authorization: Bearer ${token}" 2>/dev/null)

  if [[ $? -eq 0 && -n "$result" ]]; then
    # Pretty-print if startup mode, otherwise raw JSON
    if [[ -n "$startup" ]]; then
      echo "$result" | python3 -c "
import sys, json
data = json.load(sys.stdin)
for m in data.get('memories', []):
    tier = m.get('tier', 'L2')
    compact = m.get('compact_form') or m.get('content', '')[:100]
    print(f'[{tier}] {compact}')
" 2>/dev/null || echo "$result"
    else
      echo "$result"
    fi
  else
    echo "Error: Could not reach supervisor at localhost:${port}" >&2
    exit 1
  fi
}

# ─── sv pensive ──────────────────────────────────────────────────────────────

cmd_pensive() {
  local action="${1:?Usage: sv pensive <extract> <project> [--dry-run]}"
  shift

  case "$action" in
    extract) cmd_pensive_extract "$@" ;;
    *)
      echo "Unknown pensive action: $action (use extract)" >&2; exit 1 ;;
  esac
}

cmd_pensive_extract() {
  local target_project=""
  local dry_run=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) dry_run=true; shift ;;
      -*)        echo "Unknown option: $1" >&2; exit 1 ;;
      *)
        if [[ -z "$target_project" ]]; then
          target_project="$1"
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$target_project" ]]; then
    echo "Usage: sv pensive extract <project> [--dry-run]" >&2
    exit 1
  fi

  local project_dir="$HOME/projects/${target_project}"
  if [[ ! -d "$project_dir" ]]; then
    echo "Error: Project directory not found: $project_dir" >&2
    exit 1
  fi

  echo "Scanning project: $target_project ($project_dir)"
  [[ "$dry_run" == "true" ]] && echo "[DRY RUN] No memories will be written."

  # ── Build list of knowledge source files ──────────────────────────────────
  local sources=()

  _add_source() {
    local f="$1"
    if [[ -f "$f" && -s "$f" ]]; then
      local size
      size=$(stat -c%s "$f" 2>/dev/null || stat -f%z "$f" 2>/dev/null || echo 0)
      if [[ "$size" -lt 51200 ]]; then
        sources+=("$f")
      else
        echo "  Skipping (>50KB): $f"
      fi
    fi
  }

  # Fixed candidates
  _add_source "$project_dir/CLAUDE.md"
  _add_source "$project_dir/README.md"
  _add_source "$project_dir/tools/README.md"

  # .claude/rules/*.md
  for f in "$project_dir/.claude/rules/"*.md; do
    _add_source "$f"
  done

  # .claude/settings.local.json
  _add_source "$project_dir/.claude/settings.local.json"

  # .claude/transcript-excerpt.md
  _add_source "$project_dir/.claude/transcript-excerpt.md"

  # docs/*.md (up to 20)
  local doc_count=0
  for f in "$project_dir/docs/"*.md; do
    [[ $doc_count -ge 20 ]] && break
    _add_source "$f" && ((doc_count++)) || true
  done

  # tools/*/README.md
  for f in "$project_dir/tools/"*/README.md; do
    _add_source "$f"
  done

  # tools/*/USAGE.txt and USAGE.md
  for f in "$project_dir/tools/"*/USAGE.txt "$project_dir/tools/"*/USAGE.md; do
    _add_source "$f"
  done

  if [[ ${#sources[@]} -eq 0 ]]; then
    echo "No knowledge sources found in $project_dir"
    exit 0
  fi

  echo "Found ${#sources[@]} source file(s)."

  # ── Fetch existing memories for deduplication (skip in dry-run for speed) ──
  local existing_memories=""
  if [[ "$dry_run" != "true" ]]; then
  existing_memories=$(timeout 10 sv recall --project "$target_project" --limit 50 2>/dev/null \
    | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    for m in data.get('memories', []):
        print(m.get('content', m.get('compact_form', '')))
except Exception:
    pass
" 2>/dev/null || true)
  fi

  # ── claude -p extraction prompt ───────────────────────────────────────────
  local extraction_prompt='Extract operational knowledge from this project file. Focus on:
- How to connect to remote systems (SSH, API endpoints, ports, credentials)
- Command recipes that work (and gotchas about what does not work)
- Tool usage patterns and deployment instructions
- File locations and data layouts on remote systems
- Critical rules and constraints the user has documented

Output ONLY the operational knowledge as numbered items, one per line.
Each item should be self-contained (understandable without reading the source file).
Skip architectural descriptions, code structure, and generic documentation.
If the file has no operational knowledge, output: NONE
Keep each item under 200 characters.'

  # ── Fallback heuristic extractor (when claude -p unavailable) ─────────────
  _heuristic_extract() {
    local file="$1"
    # Strip supervisor boilerplate from CLAUDE.md
    local content
    content=$(python3 -c "
import sys, re
with open(sys.argv[1]) as f:
    text = f.read()
# Remove supervisor boilerplate block
text = re.sub(r'<!--\s*SUPERVISOR-START\s*-->.*?<!--\s*SUPERVISOR-END\s*-->', '', text, flags=re.DOTALL)
print(text)
" "$file" 2>/dev/null || cat "$file")

    echo "$content" | grep -E '(ssh |scp |rsync |curl |wget |https?://|[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+|:[0-9]{2,5}|/home/|/etc/|/var/|/opt/|password|token|key=|API_|SECRET|PORT=|HOST=|\.sh |python3 |node |docker |kubectl )' \
      | grep -v '^\s*#' \
      | grep -v '<!--' \
      | sed 's/^\s*//' \
      | grep -v '^$' \
      | head -20 \
      | nl -w2 -s'. '
  }

  # ── Process each source file ───────────────────────────────────────────────
  local files_scanned=0
  local memories_written=0
  local errors=0

  for src in "${sources[@]}"; do
    local rel="${src#$project_dir/}"
    echo ""
    echo "── $rel"
    ((files_scanned++))

    # Strip supervisor boilerplate if this is CLAUDE.md
    local file_content
    file_content=$(python3 -c "
import sys, re
with open(sys.argv[1]) as f:
    text = f.read()
if sys.argv[1].endswith('CLAUDE.md'):
    text = re.sub(r'<!--\s*SUPERVISOR-START\s*-->.*?<!--\s*SUPERVISOR-END\s*-->', '', text, flags=re.DOTALL)
print(text)
" "$src" 2>/dev/null)

    if [[ -z "$file_content" ]]; then
      echo "  (empty after preprocessing — skipping)"
      continue
    fi

    # Try claude -p extraction (skip for dry-run — use heuristic only)
    local raw_items=""
    if [[ "$dry_run" != "true" ]] && command -v claude >/dev/null 2>&1; then
      raw_items=$(echo "$file_content" | \
        timeout 60 claude -p "$extraction_prompt" --output-format text 2>/dev/null || true)
      if [[ -z "$raw_items" ]]; then
        echo "  Warning: claude -p returned empty output — falling back to heuristic"
        raw_items=$(_heuristic_extract "$src")
      fi
    else
      echo "  Note: claude not found — using heuristic extractor"
      raw_items=$(_heuristic_extract "$src")
    fi

    # Parse numbered items: strip leading "N. " or "N) "
    local items=()
    while IFS= read -r line; do
      # Strip leading number+punctuation+space
      local item
      item=$(echo "$line" | sed 's/^[0-9]\+[.)]\s*//' | sed 's/^\s*//' | sed 's/\s*$//')
      [[ -z "$item" || "$item" == "NONE" ]] && continue
      [[ ${#item} -gt 200 ]] && item="${item:0:200}"
      items+=("$item")
    done <<< "$raw_items"

    if [[ ${#items[@]} -eq 0 ]]; then
      echo "  No operational knowledge found."
      [[ -z "$raw_items" ]] || echo "  (Output was: ${raw_items:0:100})"
      sleep 2
      continue
    fi

    echo "  Extracted ${#items[@]} item(s)."

    for item in "${items[@]}"; do
      # Deduplication: simple substring check against existing memories
      local is_dup=false
      if [[ -n "$existing_memories" ]]; then
        # Check if first 60 chars of item appear in existing memories
        local prefix="${item:0:60}"
        if echo "$existing_memories" | grep -qF "$prefix" 2>/dev/null; then
          is_dup=true
        fi
      fi

      if [[ "$is_dup" == "true" ]]; then
        echo "  [DUP] $item"
        continue
      fi

      if [[ "$dry_run" == "true" ]]; then
        echo "  [WOULD WRITE] $item"
        ((memories_written++))
      else
        local result
        if result=$(sv remember "$item" --project "$target_project" --tier L2 --type infrastructure 2>&1); then
          echo "  [OK] $item"
          ((memories_written++))
          # Append to existing_memories so later items in this run can dedup against it
          existing_memories="${existing_memories}"$'\n'"${item}"
        else
          echo "  [WARN] Failed to write memory: $result"
          ((errors++))
        fi
      fi
    done

    sleep 2
  done

  echo ""
  echo "─────────────────────────────────────────────"
  echo "Files scanned:    $files_scanned"
  echo "Memories written: $memories_written"
  [[ $errors -gt 0 ]] && echo "Errors:           $errors"
  [[ "$dry_run" == "true" ]] && echo "(dry run — nothing was written)"
  echo "─────────────────────────────────────────────"
}

# ─── Dispatch ────────────────────────────────────────────────────────────────

cmd="${1:?Usage: sv <pub|chat|read|retain|clear|request|respond|task|remember|recall|pensive> ...}"
shift
case "$cmd" in
  pub)      cmd_pub "$@" ;;
  chat)     cmd_chat "$@" ;;
  read)     cmd_read "$@" ;;
  retain)   cmd_retain "$@" ;;
  clear)    cmd_clear "$@" ;;
  request)  cmd_request "$@" ;;
  respond)  cmd_respond "$@" ;;
  task)     cmd_task "$@" ;;
  remember) cmd_remember "$@" ;;
  recall)   cmd_recall "$@" ;;
  pensive)  cmd_pensive "$@" ;;
  *)        echo "Unknown command: $cmd" >&2; exit 1 ;;
esac